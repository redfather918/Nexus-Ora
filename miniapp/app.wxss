/* ===== Nexus Ora Global Styles ===== */
page {
  background: #0f0f23;
  color: #e2e8f0;
  font-size: 28rpx;
  min-height: 100vh;
}

/* Page Layout */
.page { padding: 24rpx 24rpx 120rpx; min-height: 100vh; }
.container { padding: 24rpx; }

/* Page Header */
.page-header {
  display: flex; align-items: center; gap: 20rpx;
  margin-bottom: 32rpx; padding-top: 8rpx;
}
.page-icon { font-size: 64rpx; line-height: 1; }
.page-title { display: block; font-size: 40rpx; font-weight: 800; color: #E5E7EB; }
.page-subtitle { display: block; font-size: 22rpx; color: #6B7280; margin-top: 4rpx; }

/* Card */
.card {
  background: rgba(30, 30, 60, 0.7);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(139, 92, 246, 0.18);
}
.card-sm { padding: 20rpx 24rpx; }

/* Buttons */
.btn-primary {
  display: block; width: 100%;
  background: linear-gradient(135deg, #7c3aed, #a78bfa);
  color: #fff; border-radius: 20rpx; padding: 28rpx;
  text-align: center; font-size: 30rpx; font-weight: 700;
  border: none; box-shadow: 0 8rpx 32rpx rgba(124,58,237,0.4);
}
.btn-primary.loading { opacity: 0.7; }
.btn-secondary {
  display: block; background: rgba(139,92,246,.15);
  color: #c4b5fd; border-radius: 16rpx; padding: 24rpx 48rpx;
  text-align: center; font-size: 28rpx; border: 1rpx solid rgba(139,92,246,0.3);
}
.btn-outline {
  display: block; background: transparent;
  color: #a78bfa; border-radius: 16rpx; padding: 24rpx 48rpx;
  text-align: center; font-size: 28rpx; border: 1rpx solid rgba(167,139,250,0.5);
}

/* Divider */
.divider { height: 1rpx; background: rgba(255,255,255,0.07); margin: 24rpx 0; }

/* Text Utilities */
.text-purple { color: #a78bfa; }
.text-gold   { color: #fbbf24; }
.text-red    { color: #ef4444; }
.text-green  { color: #22c55e; }
.text-gray   { color: #9CA3AF; }
.text-sm     { font-size: 24rpx; color: #94a3b8; }
.text-xs     { font-size: 20rpx; color: #64748b; }
.text-lg     { font-size: 32rpx; }
.text-xl     { font-size: 36rpx; }
.text-2xl    { font-size: 40rpx; }
.font-bold   { font-weight: 700; }
.font-black  { font-weight: 900; }
.text-center { text-align: center; }

/* Flex */
.flex-row    { display: flex; flex-direction: row; align-items: center; }
.flex-col    { display: flex; flex-direction: column; }
.flex-wrap   { flex-wrap: wrap; }
.flex-1      { flex: 1; }
.justify-between { justify-content: space-between; }
.justify-center  { justify-content: center; }
.items-center    { align-items: center; }

/* Spacing */
.gap-8  { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }
.mt-8   { margin-top: 8rpx; }
.mt-12  { margin-top: 12rpx; }
.mt-16  { margin-top: 16rpx; }
.mt-24  { margin-top: 24rpx; }
.mt-32  { margin-top: 32rpx; }
.mb-8   { margin-bottom: 8rpx; }
.mb-16  { margin-bottom: 16rpx; }
.mb-24  { margin-bottom: 24rpx; }
.p-24   { padding: 24rpx; }
.p-32   { padding: 32rpx; }
.px-24  { padding-left: 24rpx; padding-right: 24rpx; }

/* Border Radius */
.radius-12  { border-radius: 12rpx; }
.radius-16  { border-radius: 16rpx; }
.radius-20  { border-radius: 20rpx; }
.radius-24  { border-radius: 24rpx; }
.radius-full{ border-radius: 9999rpx; }

/* Tags */
.tag-base {
  display: inline-block; padding: 6rpx 18rpx;
  border-radius: 40rpx; font-size: 22rpx; font-weight: 600;
}

/* Empty State */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx; text-align: center;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 30rpx; font-weight: 700; color: #E5E7EB; margin-bottom: 12rpx; }
.empty-desc  { font-size: 24rpx; color: #6B7280; line-height: 1.6; }

/* Score Ring (simple) */
.score-num { font-size: 48rpx; font-weight: 900; }
.score-label { font-size: 20rpx; color: #9CA3AF; }

/* Section Title */
.section-title {
  display: block; font-size: 28rpx; font-weight: 700;
  color: #E5E7EB; margin-bottom: 20rpx;
}

/* Input */
.inp {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx; padding: 24rpx 28rpx;
  font-size: 28rpx; color: #E5E7EB; width: 100%; box-sizing: border-box;
}
.inp::placeholder { color: #6B7280; }

/* Textarea */
.textarea {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx; padding: 24rpx 28rpx;
  font-size: 28rpx; color: #E5E7EB; width: 100%; box-sizing: border-box;
  min-height: 160rpx;
}

/* Result wrap */
.result-wrap { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: none; } }
