/* fortune.wxss */
@import "../../app.wxss";

.form-card { padding: 32rpx; }
.form-row { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 12rpx; }
.picker-btn {
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx; padding: 24rpx 28rpx; color: #6B7280; font-size: 28rpx;
}
.picker-btn.has-value { color: #E5E7EB; border-color: rgba(167,139,250,0.4); }
.picker-arrow { color: #a78bfa; }
.gender-row { display: flex; gap: 20rpx; }
.gender-btn {
  flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  color: #9CA3AF; font-size: 28rpx;
}
.gender-btn.active { background: rgba(167,139,250,0.2); border-color: #a78bfa; color: #a78bfa; font-weight: 600; }

/* Loading */
.loading-card {
  display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx;
  background: rgba(255,255,255,0.04); border-radius: 24rpx; margin-top: 32rpx;
}
.loading-spinner {
  width: 80rpx; height: 80rpx; border: 6rpx solid rgba(167,139,250,0.3);
  border-top-color: #a78bfa; border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 24rpx; color: #9CA3AF; font-size: 26rpx; }

/* Summary */
.summary-card { padding: 28rpx 24rpx; }
.summary-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 12rpx; }
.tag { padding: 8rpx 20rpx; border-radius: 40rpx; font-size: 22rpx; font-weight: 600; }
.tag-purple { background: rgba(167,139,250,0.2); color: #a78bfa; }
.tag-amber { background: rgba(245,158,11,0.2); color: #F59E0B; }
.tag-blue { background: rgba(59,130,246,0.2); color: #60A5FA; }
.tag-green { background: rgba(16,185,129,0.2); color: #34D399; }
.summary-lunar { font-size: 22rpx; color: #6B7280; }

/* Tab Nav */
.tab-nav { display: flex; background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 6rpx; margin: 24rpx 0 16rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 24rpx; color: #6B7280; border-radius: 16rpx; }
.tab.active { background: rgba(167,139,250,0.2); color: #a78bfa; font-weight: 600; }

/* 四柱 */
.bazi-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16rpx; margin-bottom: 16rpx; }
.pillar-card {
  background: rgba(255,255,255,0.05); border-radius: 20rpx; padding: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08); text-align: center;
}
.pillar-name { display: block; font-size: 20rpx; color: #6B7280; margin-bottom: 8rpx; }
.pillar-ganzhi { display: block; font-size: 40rpx; font-weight: 700; color: #a78bfa; margin-bottom: 8rpx; }
.pillar-detail { display: flex; justify-content: center; gap: 8rpx; margin-bottom: 6rpx; }
.pillar-gan { font-size: 22rpx; color: #E5E7EB; }
.pillar-wx { font-size: 20rpx; color: #9CA3AF; }
.pillar-shishen { display: block; font-size: 20rpx; color: #F59E0B; }

/* Insight */
.insight-card { padding: 24rpx; }
.insight-title { display: block; font-size: 26rpx; font-weight: 700; color: #a78bfa; margin-bottom: 12rpx; }
.insight-text { font-size: 26rpx; color: #D1D5DB; line-height: 1.7; }

/* 五行 */
.section-title { display: block; font-size: 28rpx; font-weight: 700; color: #E5E7EB; margin-bottom: 24rpx; }
.wuxing-list { display: flex; flex-direction: column; gap: 20rpx; }
.wuxing-row { display: flex; align-items: center; gap: 16rpx; }
.wuxing-name { width: 48rpx; font-size: 28rpx; font-weight: 700; color: #E5E7EB; }
.wuxing-bar-bg { flex: 1; height: 16rpx; background: rgba(255,255,255,0.08); border-radius: 8rpx; overflow: hidden; }
.wuxing-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.6s; }
.wuxing-pct { width: 40rpx; font-size: 24rpx; font-weight: 700; text-align: right; }

/* 流年 */
.fortune-list { display: flex; flex-direction: column; gap: 16rpx; }
.fortune-row { display: flex; align-items: center; gap: 16rpx; }
.f-age { width: 80rpx; font-size: 24rpx; color: #9CA3AF; }
.f-bar-bg { flex: 1; height: 14rpx; background: rgba(255,255,255,0.08); border-radius: 7rpx; overflow: hidden; }
.f-bar-fill { height: 100%; border-radius: 7rpx; }
.f-score { width: 48rpx; font-size: 24rpx; font-weight: 700; text-align: right; }

/* 大运 */
.dayun-list { display: flex; flex-direction: column; gap: 0; }
.dayun-row {
  display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.dayun-age { width: 80rpx; text-align: center; }
.dy-age-num { font-size: 36rpx; font-weight: 800; color: #a78bfa; }
.dy-age-unit { display: block; font-size: 18rpx; color: #6B7280; }
.dayun-ganzhi { flex: 1; }
.dy-gz { display: block; font-size: 32rpx; font-weight: 700; color: #E5E7EB; }
.dy-wx { font-size: 22rpx; color: #9CA3AF; }
.dayun-score { font-size: 32rpx; font-weight: 800; }

/* Actions */
.action-row { display: flex; gap: 20rpx; margin-top: 32rpx; }
.btn-secondary {
  flex: 1; padding: 28rpx; text-align: center; font-size: 28rpx; font-weight: 600;
  background: rgba(167,139,250,0.15); color: #a78bfa; border-radius: 20rpx;
  border: 1rpx solid rgba(167,139,250,0.3);
}
.btn-ghost {
  flex: 1; padding: 28rpx; text-align: center; font-size: 28rpx; font-weight: 600;
  background: rgba(255,255,255,0.05); color: #9CA3AF; border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}
