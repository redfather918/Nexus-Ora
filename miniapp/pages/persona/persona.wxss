@import "../../app.wxss";
.chat-page { padding-bottom: 160rpx; }
.persona-scroll { white-space: nowrap; margin-bottom: 24rpx; }
.persona-row { display: inline-flex; gap: 16rpx; padding: 0 4rpx 8rpx; }
.persona-card {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 160rpx; padding: 20rpx 12rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.05); border: 2rpx solid rgba(255,255,255,0.08);
  white-space: normal;
}
.persona-card.active { background: rgba(167,139,250,0.12); }
.persona-emoji { font-size: 48rpx; margin-bottom: 8rpx; }
.persona-name { font-size: 24rpx; font-weight: 700; margin-bottom: 4rpx; }
.persona-desc { font-size: 18rpx; color: #6B7280; text-align: center; line-height: 1.4; }
.chat-wrap { min-height: 400rpx; padding: 24rpx; }
.chat-empty { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.ce-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
.ce-name { font-size: 32rpx; font-weight: 700; color: #E5E7EB; margin-bottom: 8rpx; }
.ce-desc { font-size: 24rpx; color: #9CA3AF; margin-bottom: 16rpx; }
.ce-hint { font-size: 22rpx; color: #6B7280; }
.msg-row { display: flex; align-items: flex-end; gap: 12rpx; margin-bottom: 20rpx; }
.msg-row.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(167,139,250,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 32rpx;
  flex-shrink: 0;
}
.msg-bubble { max-width: 72%; padding: 20rpx 24rpx; border-radius: 24rpx; }
.user-bubble { background: linear-gradient(135deg, #7c3aed, #a78bfa); border-bottom-right-radius: 4rpx; }
.ai-bubble { background: rgba(255,255,255,0.07); border-bottom-left-radius: 4rpx; }
.msg-text { font-size: 28rpx; color: #E5E7EB; line-height: 1.6; }
.user-bubble .msg-text { color: #fff; }
.typing { display: flex; align-items: center; gap: 6rpx; padding: 20rpx 24rpx; }
.dot { font-size: 32rpx; color: #a78bfa; animation: blink 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%,80%,100% { opacity: 0.3; } 40% { opacity: 1; } }
.input-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 16rpx; padding: 20rpx 24rpx;
  background: #1a1a2e; border-top: 1rpx solid rgba(255,255,255,0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.chat-input {
  flex: 1; background: rgba(255,255,255,0.07); border-radius: 48rpx;
  padding: 20rpx 28rpx; font-size: 28rpx; color: #E5E7EB;
}
.send-btn {
  padding: 20rpx 32rpx; border-radius: 48rpx;
  background: rgba(167,139,250,0.3); color: #9CA3AF; font-size: 28rpx; font-weight: 600;
}
.send-btn.active { background: linear-gradient(135deg, #7c3aed, #a78bfa); color: #fff; }
