<view class="page chat-page">
  <view class="page-header">
    <text class="page-icon">🎭</text>
    <view>
      <text class="page-title">灵境人格</text>
      <text class="page-subtitle">AI 人格对话</text>
    </view>
  </view>

  <!-- 人格选择 -->
  <scroll-view scroll-x class="persona-scroll">
    <view class="persona-row">
      <view
        class="persona-card {{selectedPersona.id==item.id ? 'active' : ''}}"
        wx:for="{{personas}}"
        wx:key="id"
        bindtap="selectPersona"
        data-id="{{item.id}}"
        style="border-color:{{selectedPersona.id==item.id ? item.color : 'rgba(255,255,255,0.08)'}}"
      >
        <text class="persona-emoji">{{item.emoji}}</text>
        <text class="persona-name" style="color:{{selectedPersona.id==item.id ? item.color : '#9CA3AF'}}">{{item.name}}</text>
        <text class="persona-desc">{{item.desc}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 聊天区域 -->
  <view class="chat-wrap card">
    <!-- 空状态 -->
    <view wx:if="{{messages.length==0}}" class="chat-empty">
      <text class="ce-emoji">{{selectedPersona.emoji}}</text>
      <text class="ce-name">{{selectedPersona.name}}</text>
      <text class="ce-desc">{{selectedPersona.desc}}</text>
      <text class="ce-hint">说出您的问题，开始对话</text>
    </view>

    <!-- 消息列表 -->
    <view wx:else>
      <view
        class="msg-row {{item.role=='user' ? 'user' : 'ai'}}"
        wx:for="{{messages}}"
        wx:key="ts"
      >
        <view class="msg-avatar" wx:if="{{item.role=='assistant'}}">
          <text>{{selectedPersona.emoji}}</text>
        </view>
        <view class="msg-bubble {{item.role=='user' ? 'user-bubble' : 'ai-bubble'}}">
          <text class="msg-text">{{item.text}}</text>
        </view>
      </view>
      <!-- 加载中 -->
      <view class="msg-row ai" wx:if="{{loading}}">
        <view class="msg-avatar"><text>{{selectedPersona.emoji}}</text></view>
        <view class="ai-bubble typing">
          <text class="dot">•</text><text class="dot">•</text><text class="dot">•</text>
        </view>
      </view>
    </view>
    <view id="msg-end"></view>
  </view>

  <!-- 输入框 -->
  <view class="input-bar">
    <input
      class="chat-input"
      placeholder="向{{selectedPersona.name}}提问..."
      value="{{inputText}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="send"
      adjust-position="{{true}}"
    />
    <view class="send-btn {{inputText ? 'active' : ''}}" bindtap="send">
      <text>发送</text>
    </view>
  </view>
</view>
