# Nexus Ora - Environment Configuration
# Copy this to .env and fill in your keys

PORT=3000
# 本地开发默认 127.0.0.1（避免 Windows 防火墙弹窗）
# 部署到服务器时请改为 HOST=0.0.0.0
HOST=127.0.0.1
NODE_ENV=development

# DeepSeek AI (optional for MVP - uses algorithm fallback)
DEEPSEEK_API_KEY=sk-placeholder

# Stripe Payment (optional for MVP - uses demo mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# App public URL (for Stripe redirect callbacks)
# 本地开发留空即可；部署时填入真实域名，如 APP_URL=https://life.p1web.site
APP_URL=

# PayPal Payment (optional for MVP - uses demo mode)
# 美国 PayPal Business 账户获取：https://developer.paypal.com/dashboard/
# 沙箱测试：https://developer.paypal.com/dashboard/sandbox/
PAYPAL_CLIENT_ID=AchctgBYlTrzbz7Ugempzj1Kgi_ZVEorgnEhBcILR3LzTW9LCsoqG0MxurlGfyaGGLd0Zm7L3lXLlDyX
PAYPAL_CLIENT_SECRET=ELsWhnAlhBQGsOtFYxJpCgpxtzCraHISA8LyKfyvwGjTOQu2kd87_X6P6_-xHtAVUo7n-Ml7f_EyqmOl
# 生产环境用 live，沙箱测试用 sandbox
# 当前凭证为 Sandbox 凭证，上线时需替换为 Live 凭证并改为 live
PAYPAL_MODE=sandbox

# 分享图「扫码测算」引流链接（share_cards.html 中 window.__APP_URL 优先于此）
SHARE_URL=
