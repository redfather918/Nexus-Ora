/* app.wxss — 全局样式 */
page {
  background-color: #080618;
  color: #E5E7EB;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
  background: linear-gradient(170deg, #100828 0%, #0D1525 50%, #100828 100%);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #C084FC, #F472B6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-purple {
  background: rgba(168, 85, 247, 0.18);
  color: #C084FC;
  border: 1rpx solid rgba(168, 85, 247, 0.2);
}

.tag-pink {
  background: rgba(236, 72, 153, 0.18);
  color: #F472B6;
  border: 1rpx solid rgba(236, 72, 153, 0.2);
}

.tag-blue {
  background: rgba(96, 165, 250, 0.18);
  color: #60A5FA;
  border: 1rpx solid rgba(96, 165, 250, 0.2);
}

.tag-green {
  background: rgba(34, 197, 94, 0.18);
  color: #4ADE80;
  border: 1rpx solid rgba(34, 197, 94, 0.2);
}

.tag-amber {
  background: rgba(245, 158, 11, 0.18);
  color: #FCD34D;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

/* 输入框 */
.input-field {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: #E5E7EB;
  font-size: 28rpx;
  width: 100%;
}

.input-field::placeholder {
  color: #6B7280;
}

/* 加载态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  color: #6B7280;
  font-size: 24rpx;
  margin-top: 16rpx;
}
