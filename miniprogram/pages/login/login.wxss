/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  padding: 80rpx 48rpx 48rpx;
  background: linear-gradient(180deg, #0F0C1F 0%, #080618 100%);
}
.logo {
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #A855F7 0%, #6366F1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.subtitle {
  text-align: center;
  color: #9CA3AF;
  font-size: 26rpx;
  margin-top: 12rpx;
  margin-bottom: 64rpx;
}
.form-card {
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(168,85,247,0.2);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}
.form-item { margin-bottom: 32rpx; }
.form-label {
  display: block;
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  box-sizing: border-box;
}
.code-row { display: flex; gap: 16rpx; align-items: stretch; }
.code-row .form-input { flex: 1; }
.sms-btn {
  padding: 0 24rpx;
  background: rgba(168,85,247,0.15);
  border: 1rpx solid rgba(168,85,247,0.4);
  color: #A855F7;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 80rpx;
  height: 80rpx;
}
.sms-btn[disabled] { opacity: 0.5; }
.dev-tip {
  margin-top: -16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(34,197,94,0.1);
  border: 1rpx dashed #22C55E;
  border-radius: 12rpx;
  color: #22C55E;
  font-size: 24rpx;
  text-align: center;
}
.submit-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #A855F7 0%, #6366F1 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.submit-btn[disabled] { opacity: 0.5; }
.agreement {
  margin-top: 24rpx;
  text-align: center;
  color: #6B7280;
  font-size: 22rpx;
}
