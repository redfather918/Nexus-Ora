<!-- pages/login/login.wxml -->
<view class="container">
  <view class="logo">✦ Nexus Ora ✦</view>
  <view class="subtitle">登录以同步你的命盘</view>

  <view class="form-card">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <text class="form-label">验证码</text>
      <view class="code-row">
        <input class="form-input" type="number" maxlength="6" placeholder="6 位验证码" value="{{code}}" bindinput="onCodeInput" />
        <button class="sms-btn" bindtap="onSendSms" disabled="{{smsDisabled}}">{{smsText}}</button>
      </view>
    </view>

    <view class="dev-tip" wx:if="{{debugCode}}">🛠 开发模式验证码：{{debugCode}}</view>

    <button class="submit-btn" bindtap="onSubmit" disabled="{{!canSubmit}}">{{submitText}}</button>

    <view class="agreement">登录即代表同意《用户协议》和《隐私政策》</view>
  </view>
</view>
