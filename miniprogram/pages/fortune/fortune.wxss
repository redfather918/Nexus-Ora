/* pages/fortune/fortune.wxss */

.fortune-container {
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  margin: 40rpx 0 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #F3F4F6;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 50rpx 0 30rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #F3F4F6;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  padding: 0 60rpx;
  margin-top: 12rpx;
}

.form-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-top: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #E5E7EB;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  color: #E5E7EB;
  font-size: 28rpx;
}

.form-value.placeholder {
  color: #6B7280;
}

.form-radio {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  color: #E5E7EB;
  font-size: 28rpx;
}

.radio-item radio {
  margin-right: 12rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

/* 结果态 */
.result-state {
  margin-top: 24rpx;
}

.overview-card {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15));
  border: 1rpx solid rgba(168, 85, 247, 0.25);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #F3F4F6;
  margin-bottom: 16rpx;
}

.overview-text {
  font-size: 28rpx;
  color: #E5E7EB;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.overview-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 18rpx 12rpx;
  text-align: center;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 6rpx;
}

.meta-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #F3F4F6;
}

.detail-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #F3F4F6;
  margin-bottom: 28rpx;
}

.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dim-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.dim-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #E5E7EB;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 800;
  color: #C084FC;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.dim-summary {
  font-size: 26rpx;
  color: #E5E7EB;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.dim-advice {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

.ages-row {
  display: flex;
  gap: 24rpx;
}

.ages-block {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  padding: 24rpx;
}

.ages-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #F3F4F6;
  margin-bottom: 16rpx;
}

.ages-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.age-tag {
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.age-tag.best {
  background: rgba(74, 222, 128, 0.15);
  color: #4ADE80;
  border: 1rpx solid rgba(74, 222, 128, 0.2);
}

.age-tag.caution {
  background: rgba(248, 113, 113, 0.15);
  color: #F87171;
  border: 1rpx solid rgba(248, 113, 113, 0.2);
}

.reset-btn {
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #9CA3AF;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
}

.reset-btn::after {
  border: none;
}
