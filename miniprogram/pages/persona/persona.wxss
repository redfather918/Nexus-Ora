/* pages/persona/persona.wxss */

.persona-container {
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  margin: 40rpx 0 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #F3F4F6;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #F3F4F6;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  padding: 0 60rpx;
}

.form-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-top: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #E5E7EB;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  color: #E5E7EB;
  font-size: 28rpx;
}

.form-value.placeholder {
  color: #6B7280;
}

.form-radio {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  color: #E5E7EB;
  font-size: 28rpx;
}

.radio-item radio {
  margin-right: 12rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.form-tip {
  text-align: center;
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 20rpx;
}

/* 结果态 */
.persona-result {
  margin-top: 24rpx;
}

.persona-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.persona-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.persona-avatar {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.persona-meta {
  flex: 1;
}

.persona-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #F3F4F6;
}

.persona-archetype {
  display: block;
  font-size: 26rpx;
  color: #C084FC;
  margin-top: 6rpx;
}

.persona-tags {
  margin-bottom: 20rpx;
}

.persona-style,
.persona-weakness {
  font-size: 26rpx;
  line-height: 1.7;
  margin-top: 14rpx;
}

.style-label,
.weakness-label {
  color: #9CA3AF;
}

.style-text,
.weakness-text {
  color: #E5E7EB;
}

/* 对话卡片 */
.chat-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
  padding: 28rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  height: 760rpx;
}

.chat-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #F3F4F6;
  margin-bottom: 20rpx;
  text-align: center;
}

.chat-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.chat-message {
  margin-bottom: 24rpx;
}

.message {
  display: flex;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  flex-shrink: 0;
  margin: 0 16rpx;
}

.assistant-avatar {
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
}

.user-avatar {
  background: rgba(96, 165, 250, 0.8);
}

.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-wrap: break-word;
}

.assistant-bubble {
  background: rgba(168, 85, 247, 0.15);
  border: 1rpx solid rgba(168, 85, 247, 0.25);
  color: #E5E7EB;
  border-top-left-radius: 4rpx;
}

.user-bubble {
  background: rgba(96, 165, 250, 0.18);
  border: 1rpx solid rgba(96, 165, 250, 0.25);
  color: #E5E7EB;
  border-top-right-radius: 4rpx;
}

.typing {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 40rpx;
  margin-bottom: 16rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #A855F7;
  margin: 0 6rpx;
  animation: bounce 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.chat-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: #E5E7EB;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 78rpx;
  line-height: 78rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  opacity: 0.5;
}

.reset-btn {
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #9CA3AF;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
}

.reset-btn::after {
  border: none;
}
