/* pages/ziwei/ziwei.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0F0C1F 0%, #1A1438 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
}

/* ===== 空状态（引导卡片） ===== */
.empty-state {
  padding-top: 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 56rpx;
}

.form-card {
  background: rgba(168, 85, 247, 0.08);
  border: 1rpx solid rgba(168, 85, 247, 0.3);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #D1D5DB;
  margin-bottom: 16rpx;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
}

.form-value {
  font-size: 30rpx;
  color: #FFFFFF;
}

.form-value.placeholder {
  color: #6B7280;
}

.form-radio {
  display: flex;
  gap: 40rpx;
  padding: 16rpx 0;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #FFFFFF;
  font-size: 30rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #A855F7 0%, #6366F1 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 28rpx 0;
  margin-top: 24rpx;
  border: none;
}

.submit-btn[disabled] {
  background: #374151;
  color: #6B7280;
}

.form-tip {
  text-align: center;
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 20rpx;
}

/* ===== 结果状态 ===== */
.user-info {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.user-birth {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.chart-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 32rpx;
}

.chart-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 24rpx;
  text-align: center;
}

.palace-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.palace {
  background: rgba(168, 85, 247, 0.1);
  border: 1rpx solid rgba(168, 85, 247, 0.3);
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.palace-name {
  font-size: 24rpx;
  color: #A855F7;
  margin-bottom: 8rpx;
}

.palace-star {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.palace-empty {
  font-size: 24rpx;
  color: #6B7280;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 24rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.action-btn.primary {
  background: linear-gradient(135deg, #A855F7 0%, #6366F1 100%);
  border: none;
}
