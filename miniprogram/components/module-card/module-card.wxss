/* components/module-card/module-card.wxss */
.module-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.module-card:active {
  background: rgba(255, 255, 255, 0.08);
}

.mc-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.mc-icon {
  font-size: 40rpx;
}

.mc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.mc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #E5E7EB;
}

.mc-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.mc-arrow {
  font-size: 36rpx;
  color: #4B5563;
  margin-left: 16rpx;
}
