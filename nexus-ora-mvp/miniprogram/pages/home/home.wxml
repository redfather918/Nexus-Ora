<!-- pages/home/home.wxml -->
<view class="container home-container">
  <!-- 顶部用户条 -->
  <view class="user-bar">
    <block wx:if="{{isLoggedIn}}">
      <view class="user-info" bindtap="onUserTap">
        <view class="user-avatar">{{userInfo.nickname || '我'}}</view>
        <view class="user-meta">
          <text class="user-name">{{userInfo.nickname || '命主'}}</text>
          <text class="user-tip">查看我的命盘</text>
        </view>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </block>
    <block wx:else>
      <view class="login-prompt" bindtap="goLogin">
        <text class="login-icon">🔮</text>
        <text class="login-text">登录解锁完整功能</text>
        <text class="login-arrow">›</text>
      </view>
    </block>
  </view>

  <!-- 品牌区 -->
  <view class="brand-area">
    <view class="brand-logo">✦</view>
    <text class="brand-name">NEXUS ORA</text>
  </view>
  <text class="brand-slogan">探索你的命运密码</text>

  <!-- 八模块入口网格 -->
  <view class="module-grid">
    <view class="module-item" wx:for="{{modules}}" wx:key="id" bindtap="goModule" data-url="{{item.url}}">
      <view class="module-icon-wrap" style="background: {{item.bgColor}};">
        <text class="module-icon">{{item.icon}}</text>
      </view>
      <text class="module-name">{{item.name}}</text>
      <text class="module-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="home-footer">
    <text class="footer-text">AI 原生玄学平台 · 灵境八部</text>
    <text class="footer-sub">仅供娱乐参考，不构成任何决策建议</text>
  </view>
</view>
