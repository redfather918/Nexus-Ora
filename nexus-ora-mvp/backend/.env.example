# Nexus Ora - Environment Configuration
# Copy this to .env and fill in your keys

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# DeepSeek AI (optional for MVP - uses algorithm fallback)
DEEPSEEK_API_KEY=sk-placeholder

# Stripe Payment (optional for MVP - uses demo mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# PayPal Payment (optional for MVP - uses demo mode)
# 在 Admin 页面 (#admin) 可动态配置，以下仅为初始默认值
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# 管理员密码（用于 /#admin 配置页面登录）
# 可在 Admin 页面内修改
ADMIN_PASSWORD=nexusadmin

# 分享图「扫码测算」引流链接（注入至 share_cards.html 所有扫码按钮 href）
# 部署时填入真实域名，如 SHARE_URL=https://nexus-ora.example.com
SHARE_URL=
