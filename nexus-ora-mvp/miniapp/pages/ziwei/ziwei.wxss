@import "../../app.wxss";
.form-card { padding: 32rpx; }
.form-row { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 12rpx; }
.picker-btn { display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; padding: 24rpx; color: #6B7280; font-size: 28rpx; }
.picker-btn.has-value { color: #E5E7EB; border-color: rgba(167,139,250,0.4); }
.picker-arrow { color: #a78bfa; }
.gender-row { display: flex; gap: 20rpx; }
.gender-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); color: #9CA3AF; font-size: 28rpx; }
.gender-btn.active { background: rgba(167,139,250,0.2); border-color: #a78bfa; color: #a78bfa; font-weight: 600; }
.ziwei-hero { text-align: center; padding: 36rpx; }
.zh-title { display: block; font-size: 40rpx; font-weight: 900; color: #a78bfa; margin-bottom: 20rpx; }
.zh-tags { display: flex; justify-content: center; gap: 16rpx; flex-wrap: wrap; }
.ztag { padding: 8rpx 20rpx; background: rgba(167,139,250,0.15); color: #a78bfa; border-radius: 40rpx; font-size: 22rpx; font-weight: 600; }
.tab-nav { display: flex; background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 6rpx; margin: 16rpx 0; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 26rpx; color: #6B7280; border-radius: 16rpx; }
.tab.active { background: rgba(167,139,250,0.2); color: #a78bfa; font-weight: 600; }
.palace-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; padding: 20rpx; }
.palace-cell { background: rgba(255,255,255,0.04); border-radius: 12rpx; padding: 16rpx; border: 1rpx solid rgba(255,255,255,0.06); text-align: center; }
.palace-cell.is-ming { background: rgba(167,139,250,0.15); border-color: #a78bfa; }
.p-name { display: block; font-size: 22rpx; color: #9CA3AF; margin-bottom: 6rpx; }
.p-stars { display: block; font-size: 26rpx; font-weight: 700; color: #F59E0B; }
.p-sub-stars { display: block; font-size: 18rpx; color: #6B7280; margin-top: 4rpx; }
.insight-text { font-size: 26rpx; color: #D1D5DB; line-height: 1.7; }
