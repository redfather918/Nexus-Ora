@import "../../app.wxss";
.streak-card { display: flex; align-items: center; justify-content: space-around; padding: 32rpx; }
.streak-row { display: flex; align-items: center; justify-content: space-around; width: 100%; }
.streak-num { display: block; font-size: 64rpx; font-weight: 900; color: #F59E0B; line-height: 1; }
.streak-lbl { display: block; font-size: 22rpx; color: #9CA3AF; }
.streak-fire { font-size: 60rpx; }
.done-num { display: block; font-size: 64rpx; font-weight: 900; color: #a78bfa; line-height: 1; }
.done-lbl { display: block; font-size: 22rpx; color: #9CA3AF; }
.tab-nav { display: flex; background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 6rpx; margin-bottom: 24rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 26rpx; color: #6B7280; border-radius: 16rpx; }
.tab.active { background: rgba(167,139,250,0.2); color: #a78bfa; font-weight: 600; }
.prac-item { display: flex; align-items: center; gap: 20rpx; padding: 28rpx; }
.prac-item.done { opacity: 0.6; }
.pi-emoji { font-size: 48rpx; }
.pi-info { flex: 1; }
.pi-name { display: block; font-size: 28rpx; font-weight: 700; color: #E5E7EB; }
.pi-desc { display: block; font-size: 22rpx; color: #9CA3AF; margin-top: 4rpx; }
.pi-check { font-size: 36rpx; }
/* Practice modal */
.practice-modal { animation: fadeIn 0.3s ease; }
.practice-card { text-align: center; padding: 48rpx 32rpx; }
.prac-emoji { display: block; font-size: 96rpx; margin-bottom: 16rpx; }
.prac-name { display: block; font-size: 36rpx; font-weight: 800; color: #a78bfa; margin-bottom: 24rpx; }
.prac-hint { display: block; font-size: 26rpx; color: #9CA3AF; margin-bottom: 20rpx; }
.timer-display { display: block; font-size: 96rpx; font-weight: 900; color: #E5E7EB; letter-spacing: 4rpx; margin: 16rpx 0; font-variant-numeric: tabular-nums; }
.timer-bar-bg { height: 12rpx; background: rgba(255,255,255,0.1); border-radius: 6rpx; overflow: hidden; margin: 20rpx 0 24rpx; }
.timer-bar-fill { height: 100%; background: linear-gradient(90deg, #a78bfa, #F59E0B); border-radius: 6rpx; transition: width 1s linear; }
.timer-hint { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 32rpx; }
.prac-btns { display: flex; gap: 20rpx; }
.textarea { width: 100%; box-sizing: border-box; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; color: #E5E7EB; min-height: 200rpx; }
@keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.h-item { padding: 24rpx; }
.hi-top { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.hi-practice { font-size: 28rpx; font-weight: 700; color: #E5E7EB; }
.hi-date { font-size: 22rpx; color: #6B7280; }
.hi-duration { display: block; font-size: 22rpx; color: #9CA3AF; }
.hi-journal { display: block; font-size: 24rpx; color: #a78bfa; margin-top: 8rpx; line-height: 1.5; }
