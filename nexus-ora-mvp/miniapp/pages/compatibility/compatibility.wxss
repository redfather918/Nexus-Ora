@import "../../app.wxss";
.person-card { padding: 28rpx; }
.person-label-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.person-badge { padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 26rpx; font-weight: 700; }
.person-badge.a { background: rgba(167,139,250,0.2); color: #a78bfa; }
.person-badge.b { background: rgba(236,72,153,0.2); color: #EC4899; }
.gender-row { display: flex; gap: 12rpx; }
.gender-btn {
  padding: 12rpx 24rpx; border-radius: 40rpx; font-size: 24rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); color: #9CA3AF;
}
.gender-btn.active { background: rgba(167,139,250,0.2); border-color: #a78bfa; color: #a78bfa; font-weight: 600; }
.picker-btn { display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; padding: 24rpx; color: #6B7280; font-size: 28rpx; }
.picker-btn.has-value { color: #E5E7EB; border-color: rgba(167,139,250,0.4); }
.picker-arrow { color: #a78bfa; }
.heart-divider { text-align: center; font-size: 48rpx; margin: 4rpx 0; }
.compat-hero { text-align: center; padding: 40rpx; }
.compat-avatars { display: flex; align-items: center; justify-content: center; gap: 32rpx; margin-bottom: 20rpx; }
.avatar-a, .avatar-b { width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(167,139,250,0.2); display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #a78bfa; }
.avatar-b { background: rgba(236,72,153,0.2); color: #EC4899; }
.compat-score-wrap { text-align: center; }
.compat-score { display: block; font-size: 80rpx; font-weight: 900; color: #a78bfa; }
.compat-score-lbl { display: block; font-size: 22rpx; color: #9CA3AF; }
.compat-level { font-size: 30rpx; font-weight: 700; color: #F59E0B; }
.tab-nav { display: flex; background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 6rpx; margin: 16rpx 0; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 26rpx; color: #6B7280; border-radius: 16rpx; }
.tab.active { background: rgba(167,139,250,0.2); color: #a78bfa; font-weight: 600; }
.dim-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx; }
.dim-emoji { font-size: 32rpx; width: 48rpx; text-align: center; }
.dim-left { flex: 1; }
.dim-name { display: block; font-size: 24rpx; color: #E5E7EB; margin-bottom: 8rpx; font-weight: 600; }
.dim-bar-bg { height: 14rpx; background: rgba(255,255,255,0.08); border-radius: 7rpx; overflow: hidden; }
.dim-bar-fill { height: 100%; border-radius: 7rpx; }
.dim-score { width: 56rpx; font-size: 28rpx; font-weight: 800; text-align: right; }
.insight-text { font-size: 26rpx; color: #D1D5DB; line-height: 1.7; }
