@import "../../app.wxss";
.method-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.method-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx 8rpx;
  background: rgba(255,255,255,0.05); border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.08);
}
.method-btn.active { background: rgba(167,139,250,0.15); border-color: #a78bfa; }
.m-emoji { font-size: 40rpx; margin-bottom: 6rpx; }
.m-name { font-size: 22rpx; color: #9CA3AF; }
.method-btn.active .m-name { color: #a78bfa; font-weight: 700; }
.form-label { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 8rpx; }
.textarea {
  width: 100%; box-sizing: border-box; background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1); border-radius: 16rpx;
  padding: 24rpx; font-size: 28rpx; color: #E5E7EB; min-height: 160rpx;
}
.shake-anim { display: flex; flex-direction: column; align-items: center; padding: 32rpx; }
.shake-icon { font-size: 80rpx; animation: shake 0.3s infinite alternate; }
.shake-text { font-size: 24rpx; color: #9CA3AF; margin-top: 16rpx; }
@keyframes shake { from { transform: rotate(-8deg); } to { transform: rotate(8deg); } }
.result-hero { text-align: center; padding: 48rpx 32rpx; }
.result-emoji { display: block; font-size: 96rpx; margin-bottom: 20rpx; }
.result-name { display: block; font-size: 40rpx; font-weight: 900; color: #a78bfa; margin-bottom: 12rpx; }
.result-title-line { display: block; font-size: 26rpx; color: #9CA3AF; }
.interp-text { font-size: 26rpx; color: #D1D5DB; line-height: 1.8; }
.luck-bar { display: flex; align-items: center; gap: 16rpx; background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 24rpx; margin-top: 16rpx; }
.luck-label { font-size: 24rpx; color: #9CA3AF; width: 120rpx; }
.luck-track { flex: 1; height: 16rpx; background: rgba(255,255,255,0.08); border-radius: 8rpx; overflow: hidden; }
.luck-fill { height: 100%; background: linear-gradient(90deg, #a78bfa, #F59E0B); border-radius: 8rpx; }
.luck-num { font-size: 28rpx; font-weight: 800; color: #F59E0B; width: 60rpx; text-align: right; }
