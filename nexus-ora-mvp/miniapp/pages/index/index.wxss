.hero{position:relative;text-align:center;padding:80rpx 0 48rpx;overflow:hidden}
.hero-glow{position:absolute;top:-80rpx;left:50%;margin-left:-200rpx;width:400rpx;height:400rpx;background:radial-gradient(circle,rgba(124,58,237,.3),transparent 70%)}
.hero-icon{font-size:100rpx;display:block;margin-bottom:16rpx}
.hero-title{font-size:52rpx;font-weight:700;color:#e2e8f0;display:block}
.hero-sub{font-size:28rpx;color:#94a3b8;margin-top:8rpx;display:block}
.hero-actions{margin-top:36rpx}
.module-grid{display:grid;grid-template-columns:1fr 1fr;gap:16rpx;margin-top:24rpx}
.module-card{background:rgba(30,30,60,.6);border-radius:24rpx;padding:28rpx;text-align:center;border:1rpx solid rgba(139,92,246,.1)}
.module-icon{font-size:48rpx;display:block;margin-bottom:8rpx}
.module-name{font-size:26rpx;font-weight:600;color:#e2e8f0;display:block}
.module-desc{font-size:20rpx;color:#64748b;margin-top:4rpx;display:block}
