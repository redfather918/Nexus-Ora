page{background:#0f0f23;color:#e2e8f0;font-size:28rpx}
.container{padding:24rpx}
.card{background:rgba(30,30,60,.6);border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;border:1rpx solid rgba(139,92,246,.15)}
.btn-primary{background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;border-radius:16rpx;padding:24rpx 48rpx;text-align:center;font-size:30rpx}
.btn-secondary{background:rgba(139,92,246,.15);color:#c4b5fd;border-radius:16rpx;padding:24rpx 48rpx;text-align:center;font-size:28rpx}
.text-purple{color:#a78bfa}
.text-gold{color:#fbbf24}
.text-red{color:#ef4444}
.text-green{color:#22c55e}
.text-sm{font-size:24rpx;color:#94a3b8}
.text-xs{font-size:20rpx;color:#64748b}
.flex-row{display:flex;flex-direction:row;align-items:center}
.flex-col{display:flex;flex-direction:column}
.flex-wrap{flex-wrap:wrap}
.flex-1{flex:1}
.justify-between{justify-content:space-between}
.justify-center{justify-content:center}
.items-center{align-items:center}
.text-center{text-align:center}
.gap-12{gap:12rpx}
.gap-16{gap:16rpx}
.gap-24{gap:24rpx}
.mt-12{margin-top:12rpx}
.mt-24{margin-top:24rpx}
.mb-24{margin-bottom:24rpx}
.p-24{padding:24rpx}
.radius-16{border-radius:16rpx}
.radius-24{border-radius:24rpx}
